<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="petstore.Controllers.AdminMenuController"
      spacing="12"
      alignment="CENTER"
      prefWidth="420"
      prefHeight="500">

    <Label text="Admin Dashboard"
           style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <TextField fx:id="petIdField" promptText="Enter Pet ID to remove" maxWidth="260"/>
    <Button text="Remove Pet" onAction="#removePet" maxWidth="260"/>
    <Button text="View All Pets" onAction="#viewPets" maxWidth="260"/>
    <Button text="Add Pet" onAction="#addPet" maxWidth="260"/>

    <Separator />


    <Button text="Add Inventory Item" onAction="#addInventory" maxWidth="260"/>
    <Button text="Remove Inventory Item" onAction="#removeInventory" maxWidth="260"/>
    <Button text="View Inventory" onAction="#viewInventory" maxWidth="260"/>

    <Separator />

    <Button text="Logout" onAction="#logout" maxWidth="260"/>
    <Label fx:id="messageLabel"/>
</VBox>
