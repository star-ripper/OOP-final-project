<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="470.0" prefWidth="520.0" spacing="12" style="-fx-background-color: PALEGOLDENROD;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="petstore.Controllers.LoginController">

    <!-- Title -->
    <Label prefHeight="32.0" prefWidth="346.0" style="-fx-font-size: 22px; -fx-font-weight: bold;" text="              Pet Store Login" />

    <!-- Username -->
    <TextField fx:id="usernameField" maxWidth="352.0" prefHeight="25.0" prefWidth="352.0" promptText="Username" />

    <!-- Password -->
    <PasswordField fx:id="passwordField" maxWidth="220" promptText="Password" />

    <!-- Login Button -->
    <Button maxWidth="220" onAction="#login" text="Login" />

    <!-- Sign Up Button -->
    <Button maxWidth="220" onAction="#goToSignUp" text="Sign Up" />

    <!-- Message / Error -->
    <Label fx:id="messageLabel" style="-fx-text-fill: red;" />

</VBox>
